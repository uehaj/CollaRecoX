# OpenAI API キー（必須）
OPENAI_API_KEY=your_openai_api_key_here

# 企業プロキシ環境（任意）
# HTTPS_PROXY=http://proxy.example.com:8080

# --- セキュリティ関連（任意） ------------------------------------------------
# WebSocket / セッション一覧 API で許可するオリジン（カンマ区切り）。
# 未設定の場合は「リクエストのHostと同一オリジン」および localhost を許可する。
# 公開環境では明示的に設定することを推奨。
# 例: ALLOWED_WS_ORIGINS=https://collab.example.com,https://app.example.com
# ALLOWED_WS_ORIGINS=

# 共同編集(Hocuspocus)接続に要求する共有トークン。
# 設定すると、クライアントは HocuspocusProvider の token オプションで同じ値を渡す必要がある。
# 未設定の場合は従来通りトークンなしで接続を許可する（後方互換）。
# COLLAB_AUTH_TOKEN=
